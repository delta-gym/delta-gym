rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Modo prueba: permite lectura/escritura durante desarrollo.
    // ¡IMPORTANTE! Cambiar antes de producción.
    match /{document=**} {
      allow read, write: if true;
    }
    
